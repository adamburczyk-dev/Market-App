# ============================================================
# .env.example — skopiuj do .env i uzupełnij wartości
# docker compose NIE wystartuje bez DB_PASSWORD i REDIS_PASSWORD
# ============================================================

# --- WYMAGANE ---
DB_PASSWORD=change_me_in_production_123!
REDIS_PASSWORD=change_me_redis_456!

# --- Opcjonalne (mają wartości domyślne) ---
DB_NAME=trading_db
DB_USER=trader
LOG_LEVEL=DEBUG
GRAFANA_PASSWORD=admin

# --- API Keys ---
ALPHA_VANTAGE_API_KEY=
ANTHROPIC_API_KEY=

# --- Trading ---
INITIAL_CAPITAL=100000.0
PAPER_TRADING=true
